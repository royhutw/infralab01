! =========================================================
! 2. 核心 SVI 管理介面與預設閘道
! =========================================================
! Tier 0 管理 VLAN (VLAN 10)
interface Vlan10
 description Tier 0 Switch Management
 ip address 192.168.10.250 255.255.255.0
 no ip redirects
 no shutdown

! 指向防火牆 (Router-on-a-Stick / Gateway)
